{
  "name": "healthcare-devops",
  "version": "1.0.0",
  "description": "Healthcare Appointment Booking System",
  "scripts": {
    "install:auth": "cd auth-service && npm install",
    "install:all": "npm run install:auth",
     "start": "node index.js",
    "start:auth": "cd auth-service && node index.js",
    "start:appointment": "cd appointment-service && python app.py",
    "start:frontend": "cd frontend && npx serve . -p 8080",
    "start:mongo": "echo 'Please ensure MongoDB is running locally on port 27017'",
    "dev": "concurrently \"npm run start:auth\" \"npm run start:appointment\" \"npm run start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
